@startuml
skinparam rectangle {
    BackgroundColor White
    BorderColor Black
}
skinparam circle {
    BackgroundColor White
    BorderColor Black
}

rectangle "User" as User
circle "1.0\nSubmit Feedback" as P1
circle "2.0\nValidate Entry" as P2
circle "3.0\nVerify Review ID" as P3
circle "4.0\nSave Issues" as P4
circle "5.0\nSend Alert" as P5

queue "Feedback Collection" as DB
rectangle "Administrator" as Admin

User -> P1 : Write Comment
P1 -> P2 : Raw Feedback Data
P2 -> P3 : Safe Payload
P3 -> P4 : Confirmed Details
P4 -> DB : Insert Document
P4 -> P5 : Success Log
P5 -> User : Thank You Popup
P5 -> Admin : Critical Alert

@enduml
